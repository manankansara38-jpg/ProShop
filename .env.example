NODE_ENV=development
PORT=5001
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
JWT_SECRET=your_jwt_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth (optional)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Frontend URLs
FRONTEND_URL=http://localhost:3000
PRODUCTION_DOMAIN=https://yourdomain.com
# For production: FRONTEND_URL=https://yourdomain.com

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=ProShop <your_email@gmail.com>

# Cloudinary Configuration (REQUIRED FOR IMAGE UPLOADS)
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Production Configuration
# Set NODE_ENV=production when deploying
# Make sure FRONTEND_URL is set to your production domain
# Image URLs will be served from /uploads or Cloudinary CDN
# 
# IMPORTANT: For Razorpay to load product images in checkout:
# 1. All product images MUST be uploaded to Cloudinary
# 2. Run: npm run migrate-images
# 3. This updates all product records with Cloudinary URLs
# 4. Razorpay can then access images from your production domain
